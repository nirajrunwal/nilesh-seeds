{
  "name": "Nilesh Seeds Dashboard",
  "short_name": "NileshSeeds",
  "description": "Premium Agricultural Retailer and Farmer Communication Application",
  "start_url": "/",
  "id": "/?source=pwa",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "fullscreen", "tabbed"],
  "background_color": "#F3F6F8",
  "theme_color": "#16a34a",
  "orientation": "portrait",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "/globe.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/globe.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/globe.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "form_factor": "narrow"
    },
    {
      "src": "/globe.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "form_factor": "wide"
    }
  ],
  "categories": ["business", "productivity", "agriculture", "finance"],
  "shortcuts": [
    {
      "name": "Live Farmer Dashboard",
      "url": "/farmer"
    },
    {
      "name": "Support",
      "url": "/farmer/queries"
    }
  ],
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.nileshseeds.app",
      "id": "com.nileshseeds.app"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+nilesh",
      "url": "/?action=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/csv": [".csv"],
        "application/pdf": [".pdf"]
      }
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "widgets": [
    {
      "name": "Farming Stats",
      "description": "View live farming stats",
      "tag": "farming_stats",
      "template_url": "/widgets/template.html",
      "ms_ac_holographic_extension": {
        "experience": "hologram"
      }
    }
  ],
  "note_taking": {
    "new_note_url": "/farmer/queries?new=true"
  },
  "scope_extensions": [
    {
      "origin": "https://*.vercel.app"
    },
    {
      "origin": "https://nilesh-seeds.vercel.app"
    }
  ]
}
